---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description, image, project } = Astro.props;
const siteTitle = 'Alfie McGlennon';
const pageTitle = title ? `${title} | ${siteTitle}` : `${siteTitle} — Climate Science & ML`;
const defaultDesc = 'Alfie McGlennon — MSc Climate Change and AI, University of Reading. Compound climate risk modelling with copulas and XGBoost, power-systems ML, and applied weather/climate data.';
const ogImage = image || '/favicon.svg';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description || defaultDesc} />
    <meta name="author" content="Alfie McGlennon" />
    <meta name="keywords" content="Alfie McGlennon, climate risk, compound extremes, copulas, XGBoost, ERA5, CMIP6, Destination Earth, reinsurance, ECMWF, climate change AI, MSc Reading, reinforcement learning, power systems, NESO, climate ML" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Fonts: Inter (body) + JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- OG / Social -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description || defaultDesc} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description || defaultDesc} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data — Person -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alfie McGlennon",
      "url": "https://alfiemcglennon.github.io",
      "jobTitle": "MSc Student, Climate Change and Artificial Intelligence",
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "University of Reading"
      },
      "sameAs": [
        "https://github.com/AlfieMcGlennon",
        "https://www.linkedin.com/in/alfiemcglennon"
      ],
      "knowsAbout": [
        "Climate Risk",
        "Compound Extremes",
        "Copulas",
        "Machine Learning",
        "XGBoost",
        "Reinforcement Learning",
        "ERA5",
        "CMIP6",
        "Power Systems"
      ]
    })} />
  </head>
  <body data-project={project || undefined}>
    <Nav />
    <main class="content-wrapper">
      <slot />
    </main>
    <Footer />
  </body>
</html>
