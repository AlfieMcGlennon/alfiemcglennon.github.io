---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

const {
  title = 'Alfie McGlennon | Climate Risk, ML & Compound Extremes',
  description = 'Alfie McGlennon. MSc Climate Change & AI at the University of Reading. Researching compound heat stress risk across Europe using copula-based frameworks and machine learning.',
  ogTitle = 'Alfie McGlennon | Climate Risk, ML & Compound Extremes',
  ogDescription = 'MSc Climate Change & AI researcher. Compound heat stress, copula methods, RL for grid dispatch, quantum ML for atmospheric regression.',
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : new URL('/favicon.svg', Astro.site);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alfie McGlennon',
  alternateName: 'Alfred McGlennon',
  url: 'https://alfiemcglennon.com',
  image: new URL('/favicon.svg', Astro.site).toString(),
  jobTitle: 'MSc Climate Change & AI researcher',
  description:
    'Climate-risk researcher working on compound heat-stress risk across Europe using copula-based frameworks and machine learning.',
  knowsAbout: [
    'Compound climate risk',
    'Copula methods',
    'Heat stress',
    'Machine learning',
    'XGBoost',
    'ERA5',
    'CMIP6',
    'Reinforcement learning',
    'Quantum machine learning',
    'Quantum computing',
    'Power systems',
    'Reinsurance',
  ],
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'University of Reading',
    url: 'https://www.reading.ac.uk/',
  },
  sameAs: [
    'https://github.com/AlfieMcGlennon',
    'https://www.linkedin.com/in/alfred-mcglennon-927589253/',
  ],
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Alfie McGlennon, climate risk, compound heat stress, copula, XGBoost, ERA5, CMIP6, machine learning, quantum, quantum machine learning, quantum ML, reinsurance, ECMWF, University of Reading, meteorology, DestinE, Kendall tau" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />

    <meta name="google-site-verification" content="REPLACE_WITH_GOOGLE_TOKEN" />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>
