---
const { project = 'default', size = 'small' } = Astro.props;
const height = size === 'large' ? 280 : 180;

// Deterministic pseudo-random for visual consistency between renders.
function lcg(seed) {
  let s = seed;
  return () => {
    s = (s * 1664525 + 1013904223) >>> 0;
    return s / 4294967296;
  };
}

// Pre-generate copula scatter points for compound-risk banner
const rand = lcg(42);
const copulaPoints = Array.from({ length: 110 }, () => {
  const t = rand();
  const jitter = (rand() - 0.5);
  const x = 60 + t * 680 + jitter * 110;
  const y = 240 - t * 200 + jitter * 70;
  const r = 1.5 + rand() * 1.2;
  const op = 0.35 + rand() * 0.55;
  return { x, y, r, op };
});

// Grid Tool nodes
const gridNodes = [
  { x: 380, y: 30, label: 'Sc-N' },
  { x: 360, y: 60, label: '' },
  { x: 400, y: 88, label: '' },
  { x: 350, y: 120, label: 'Sc-S' },
  { x: 380, y: 150, label: '' },
  { x: 360, y: 180, label: '' },
  { x: 410, y: 210, label: 'N-E' },
  { x: 340, y: 230, label: 'N-W' },
  { x: 430, y: 250, label: '' },
  { x: 380, y: 275, label: 'Mid' },
  { x: 420, y: 290, label: '' },
];
// Spread these horizontally for the wide banner
const gridNodesH = gridNodes.map((n, i) => ({
  x: 70 + i * 65 + (rand() - 0.5) * 16,
  y: 60 + (i % 3) * 70 + (rand() - 0.5) * 24,
  label: n.label,
}));
---

<div class={`banner banner-${project}`} style={`--banner-h: ${height}px`} aria-hidden="true">
  {project === 'grid-tool' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="#0a0a0f" />
      <g class="grid-bg" stroke="#1a1a1f" stroke-width="0.5" fill="none">
        <line x1="0" y1="80" x2="800" y2="80" />
        <line x1="0" y1="160" x2="800" y2="160" />
        <line x1="0" y1="240" x2="800" y2="240" />
        <line x1="200" y1="0" x2="200" y2="300" />
        <line x1="400" y1="0" x2="400" y2="300" />
        <line x1="600" y1="0" x2="600" y2="300" />
      </g>
      <g class="grid-lines" stroke="#ffb000" stroke-width="1" opacity="0.45" fill="none">
        {gridNodesH.slice(0, -1).map((n, i) => {
          const next = gridNodesH[i + 1];
          return <line x1={n.x} y1={n.y} x2={next.x} y2={next.y} />;
        })}
        {gridNodesH.map((n, i) => {
          const skip = gridNodesH[(i + 2) % gridNodesH.length];
          return <line x1={n.x} y1={n.y} x2={skip.x} y2={skip.y} opacity="0.3" />;
        })}
      </g>
      <g class="grid-nodes" fill="#ffb000">
        {gridNodesH.map(n => <circle cx={n.x} cy={n.y} r="3.5" />)}
      </g>
      <text x="40" y="36" fill="#665020" font-family="monospace" font-size="11" letter-spacing="2">B6F</text>
      <text x="700" y="290" fill="#665020" font-family="monospace" font-size="11" letter-spacing="2">27Z</text>
    </svg>
  )}

  {project === 'rl-dispatch' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="rl-glow">
          <feGaussianBlur stdDeviation="2.5" result="b" />
          <feMerge>
            <feMergeNode in="b" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>
      <rect width="800" height="300" fill="#0a0a0f" />
      <g stroke="#1a1a2e" stroke-width="0.5" fill="none">
        <line x1="0" y1="60" x2="800" y2="60" />
        <line x1="0" y1="120" x2="800" y2="120" />
        <line x1="0" y1="180" x2="800" y2="180" />
        <line x1="0" y1="240" x2="800" y2="240" />
        <line x1="200" y1="0" x2="200" y2="300" />
        <line x1="400" y1="0" x2="400" y2="300" />
        <line x1="600" y1="0" x2="600" y2="300" />
      </g>
      <path
        d="M 40,260 C 120,255 200,240 280,200 C 360,160 440,90 540,70 C 620,55 700,55 760,52"
        stroke="#a78bfa"
        stroke-width="2.5"
        fill="none"
        filter="url(#rl-glow)"
      />
      <path
        d="M 40,275 C 120,270 200,265 280,255 C 360,245 440,225 540,220 C 620,217 700,217 760,217"
        stroke="#7c3aed"
        stroke-width="1.2"
        fill="none"
        opacity="0.5"
      />
      <text x="40" y="26" fill="#6b5fb0" font-family="monospace" font-size="11" letter-spacing="2">REWARD</text>
      <text x="700" y="290" fill="#6b5fb0" font-family="monospace" font-size="11" letter-spacing="2">STEPS</text>
    </svg>
  )}

  {project === 'compound-risk' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="#13363c" />
      <g stroke="#1d4a52" stroke-width="0.5" fill="none">
        <line x1="60" y1="40" x2="60" y2="260" />
        <line x1="60" y1="260" x2="740" y2="260" />
      </g>
      <g class="copula-points" fill="#5fb3c4">
        {copulaPoints.map(p => (
          <circle cx={p.x} cy={p.y} r={p.r} opacity={p.op} />
        ))}
      </g>
      <text x="40" y="36" fill="#5fb3c4" font-family="monospace" font-size="11" letter-spacing="2" opacity="0.7">U2</text>
      <text x="710" y="285" fill="#5fb3c4" font-family="monospace" font-size="11" letter-spacing="2" opacity="0.7">U1</text>
    </svg>
  )}

  {project === 'climate-stripes' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <g>
        {Array.from({ length: 174 }, (_, i) => {
          const t = i / 173;
          let r, g, b;
          if (t < 0.45) {
            const u = t / 0.45;
            r = 33 + u * (210 - 33);
            g = 102 + u * (220 - 102);
            b = 172 + u * (232 - 172);
          } else if (t < 0.55) {
            r = 240;
            g = 232;
            b = 220;
          } else {
            const u = (t - 0.55) / 0.45;
            r = 240 - u * (240 - 178);
            g = 230 - u * (230 - 24);
            b = 220 - u * (220 - 43);
          }
          const colour = `rgb(${Math.round(r)},${Math.round(g)},${Math.round(b)})`;
          return <rect x={i * (800 / 174)} y="0" width={800 / 174 + 0.5} height="300" fill={colour} />;
        })}
      </g>
    </svg>
  )}

  {project === 'climate-data-quickstart' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="#0e1f1a" />
      <g class="pipelines" stroke="#059669" stroke-width="1.5" fill="none">
        <path d="M 40,60 L 760,60" opacity="0.5" />
        <path d="M 40,100 L 760,100" opacity="0.6" />
        <path d="M 40,150 L 760,150" opacity="0.75" />
        <path d="M 40,200 L 760,200" opacity="0.6" />
        <path d="M 40,240 L 760,240" opacity="0.5" />
      </g>
      <g class="pipeline-nodes" fill="#10b981">
        {[60, 100, 150, 200, 240].flatMap(y => [200, 400, 600].map(x => (
          <circle cx={x} cy={y} r="3.5" />
        )))}
      </g>
      <g class="pipeline-converge" stroke="#10b981" stroke-width="1" fill="none" opacity="0.35">
        <line x1="200" y1="60" x2="400" y2="150" />
        <line x1="200" y1="100" x2="400" y2="150" />
        <line x1="200" y1="200" x2="400" y2="150" />
        <line x1="200" y1="240" x2="400" y2="150" />
        <line x1="400" y1="150" x2="600" y2="100" />
        <line x1="400" y1="150" x2="600" y2="200" />
      </g>
      <text x="40" y="290" fill="#3d6b5b" font-family="monospace" font-size="11" letter-spacing="2">ERA5 · CMIP6 · GloFAS · UKCP18 · HadCET</text>
    </svg>
  )}

  {project === 'climate-playbook' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="#eef2f8" />
      <g class="panels">
        <rect x="120" y="60" width="560" height="40" fill="#2563eb" opacity="0.18" rx="4" />
        <rect x="100" y="105" width="600" height="40" fill="#2563eb" opacity="0.28" rx="4" />
        <rect x="140" y="150" width="520" height="40" fill="#2563eb" opacity="0.4" rx="4" />
        <rect x="110" y="195" width="580" height="40" fill="#2563eb" opacity="0.55" rx="4" />
        <rect x="160" y="240" width="480" height="40" fill="#2563eb" opacity="0.7" rx="4" />
      </g>
      <g font-family="monospace" font-size="11" fill="#4263a0" letter-spacing="2">
        <text x="155" y="86">KS1</text>
        <text x="135" y="131">KS2</text>
        <text x="175" y="176">KS3</text>
        <text x="145" y="221">KS4</text>
        <text x="195" y="266">KS5</text>
      </g>
    </svg>
  )}

  {project === 'quantum-ml' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="#0c0a18" />
      <g class="qubits" stroke="#6d28d9" stroke-width="1.2" fill="none">
        <line x1="60" y1="80" x2="740" y2="80" />
        <line x1="60" y1="140" x2="740" y2="140" />
        <line x1="60" y1="200" x2="740" y2="200" />
        <line x1="60" y1="260" x2="740" y2="260" />
      </g>
      <g class="gates" fill="#8b5cf6" stroke="#6d28d9" stroke-width="1">
        <rect x="140" y="70" width="22" height="22" rx="2" />
        <rect x="140" y="190" width="22" height="22" rx="2" />
        <circle cx="240" cy="80" r="4" fill="#a78bfa" />
        <line x1="240" y1="80" x2="240" y2="140" stroke="#a78bfa" stroke-width="1" />
        <circle cx="240" cy="140" r="9" fill="none" stroke="#a78bfa" />
        <line x1="232" y1="140" x2="248" y2="140" stroke="#a78bfa" />
        <line x1="240" y1="132" x2="240" y2="148" stroke="#a78bfa" />
        <rect x="340" y="130" width="22" height="22" rx="2" />
        <rect x="340" y="250" width="22" height="22" rx="2" />
        <circle cx="440" cy="200" r="4" fill="#a78bfa" />
        <line x1="440" y1="200" x2="440" y2="260" stroke="#a78bfa" stroke-width="1" />
        <circle cx="440" cy="260" r="9" fill="none" stroke="#a78bfa" />
        <line x1="432" y1="260" x2="448" y2="260" stroke="#a78bfa" />
        <line x1="440" y1="252" x2="440" y2="268" stroke="#a78bfa" />
        <rect x="540" y="70" width="22" height="22" rx="2" />
        <rect x="540" y="130" width="22" height="22" rx="2" />
        <rect x="540" y="190" width="22" height="22" rx="2" />
        <rect x="540" y="250" width="22" height="22" rx="2" />
        <rect x="640" y="70" width="40" height="22" rx="2" fill="#0c0a18" stroke="#a78bfa" />
        <rect x="640" y="130" width="40" height="22" rx="2" fill="#0c0a18" stroke="#a78bfa" />
        <rect x="640" y="190" width="40" height="22" rx="2" fill="#0c0a18" stroke="#a78bfa" />
        <rect x="640" y="250" width="40" height="22" rx="2" fill="#0c0a18" stroke="#a78bfa" />
      </g>
      <g fill="#6d28d9" font-family="monospace" font-size="11" letter-spacing="2" opacity="0.7">
        <text x="30" y="84">|0⟩</text>
        <text x="30" y="144">|0⟩</text>
        <text x="30" y="204">|0⟩</text>
        <text x="30" y="264">|0⟩</text>
      </g>
    </svg>
  )}

  {project === 'india-demand' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="#fdf4e8" />
      <g class="india-blocks">
        <rect x="320" y="40" width="80" height="50" fill="#ea580c" opacity="0.35" rx="2" />
        <rect x="400" y="40" width="60" height="40" fill="#ea580c" opacity="0.25" rx="2" />
        <rect x="280" y="90" width="100" height="50" fill="#ea580c" opacity="0.5" rx="2" />
        <rect x="380" y="90" width="80" height="50" fill="#ea580c" opacity="0.45" rx="2" />
        <rect x="240" y="140" width="80" height="50" fill="#ea580c" opacity="0.55" rx="2" />
        <rect x="320" y="140" width="80" height="50" fill="#ea580c" opacity="0.7" rx="2" />
        <rect x="400" y="140" width="60" height="50" fill="#ea580c" opacity="0.4" rx="2" />
        <rect x="260" y="190" width="70" height="50" fill="#ea580c" opacity="0.85" rx="2" />
        <rect x="330" y="190" width="70" height="50" fill="#ea580c" opacity="0.9" rx="2" />
        <rect x="290" y="240" width="60" height="40" fill="#ea580c" opacity="0.95" rx="2" />
      </g>
      <text x="40" y="40" fill="#a04a18" font-family="monospace" font-size="11" letter-spacing="2">R² · STATE</text>
    </svg>
  )}

  {project === 'nimbus-valley' && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
      <rect width="800" height="300" fill="#88c0a8" />
      <g fill="#5da080">
        {Array.from({ length: 40 }, (_, i) => (
          <rect x={i * 20} y={180 + (i % 3) * 8} width="20" height="120" />
        ))}
      </g>
      <g fill="#3f7758">
        <rect x="120" y="160" width="20" height="20" />
        <rect x="140" y="150" width="20" height="30" />
        <rect x="160" y="160" width="20" height="20" />
        <rect x="500" y="160" width="20" height="20" />
        <rect x="520" y="150" width="20" height="30" />
        <rect x="540" y="160" width="20" height="20" />
      </g>
      <g fill="#ffffff" opacity="0.8">
        <rect x="200" y="80" width="40" height="10" />
        <rect x="190" y="90" width="60" height="10" />
        <rect x="200" y="100" width="50" height="10" />
        <rect x="540" y="60" width="40" height="10" />
        <rect x="530" y="70" width="60" height="10" />
      </g>
    </svg>
  )}

  {!['grid-tool','rl-dispatch','compound-risk','climate-stripes','climate-data-quickstart','climate-playbook','quantum-ml','india-demand','nimbus-valley'].includes(project) && (
    <svg viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <rect width="800" height="300" fill="var(--bg-raised)" />
    </svg>
  )}
</div>

<style>
  .banner {
    width: 100%;
    height: var(--banner-h, 180px);
    overflow: hidden;
    border-radius: 6px;
    margin-bottom: 1.5rem;
    border: 1px solid var(--rule);
  }

  .banner svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Animations, all reduced-motion-safe */
  .banner-grid-tool .grid-lines line {
    animation: pulse-lines 4.5s ease-in-out infinite;
  }
  @keyframes pulse-lines {
    0%, 100% { opacity: 0.45; }
    50% { opacity: 0.85; }
  }

  .banner-rl-dispatch path:first-of-type {
    stroke-dasharray: 1400;
    stroke-dashoffset: 0;
  }

  .banner-compound-risk .copula-points circle {
    animation: drift-point 8s ease-in-out infinite alternate;
  }
  @keyframes drift-point {
    from { transform: translate(0, 0); }
    to { transform: translate(2px, -1px); }
  }

  .banner-climate-data-quickstart .pipelines path {
    stroke-dasharray: 4 6;
    animation: flow 30s linear infinite;
  }
  @keyframes flow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -200; }
  }

  .banner-quantum-ml .qubits line {
    stroke-dasharray: 2 4;
    animation: qpulse 6s linear infinite;
  }
  @keyframes qpulse {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -60; }
  }

  @media (prefers-reduced-motion: reduce) {
    .banner-grid-tool .grid-lines line,
    .banner-compound-risk .copula-points circle,
    .banner-climate-data-quickstart .pipelines path,
    .banner-quantum-ml .qubits line {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .banner { height: calc(var(--banner-h, 180px) * 0.7); }
  }
</style>
