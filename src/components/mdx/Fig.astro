---
const { src, alt, num, caption } = Astro.props;
---

<figure class="fig">
  <img src={src} alt={alt || caption || ''} loading="lazy" />
  {(num || caption) && (
    <figcaption class="fig-caption">
      {num && <span class="fig-num">Fig. {num}.</span>}
      {caption && <span class="fig-text">{caption}</span>}
      {!caption && <slot />}
    </figcaption>
  )}
</figure>

<style>
  .fig {
    margin: 2.75rem 0 2rem;
  }

  .fig img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--rule);
  }

  .fig-caption {
    margin-top: 0.75rem;
    font-family: var(--font-label);
    font-size: 0.78rem;
    line-height: 1.5;
    color: var(--ink-dim);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
  }

  .fig-num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    font-feature-settings: 'tnum' 1, 'lnum' 1;
  }

  .fig-text {
    color: var(--ink-dim);
    font-style: italic;
    font-family: var(--font-display);
    font-size: 0.98rem;
  }
</style>
