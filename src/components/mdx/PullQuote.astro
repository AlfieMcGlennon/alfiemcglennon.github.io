---
const { attribution } = Astro.props;
---

<aside class="pull-quote" role="note">
  <span class="pq-glyph" aria-hidden="true">&ldquo;</span>
  <blockquote class="pq-body">
    <slot />
  </blockquote>
  {attribution && <cite class="pq-attribution">&mdash; {attribution}</cite>}
</aside>

<style>
  .pull-quote {
    position: relative;
    margin: 3.5rem 0;
    padding: 1.5rem 0 1.25rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    text-align: center;
  }

  .pq-glyph {
    position: absolute;
    top: 0.4rem;
    left: 50%;
    transform: translate(-50%, -55%);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 6rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.35;
    background: var(--bg);
    padding: 0 0.3em;
    z-index: 1;
  }

  .pq-body {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    line-height: 1.4;
    color: var(--ink);
    margin: 0;
    padding: 0;
    border: 0;
    max-width: 36ch;
    margin-inline: auto;
  }

  .pq-body :global(p) {
    margin: 0;
    color: inherit;
  }

  .pq-attribution {
    display: block;
    margin-top: 1rem;
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 500;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--ink-faint);
  }
</style>
