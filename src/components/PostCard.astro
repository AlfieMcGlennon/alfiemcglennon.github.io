---
const { title, description, date, slug, project, tags } = Astro.props;

const formatted = new Date(date).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}/`} class="post-card card" data-project={project || undefined}>
  <div class="post-card-inner">
    <time class="post-date" datetime={new Date(date).toISOString()}>{formatted}</time>
    <h3 class="post-title">{title}</h3>
    <p class="post-desc">{description}</p>
    {tags && tags.length > 0 && (
      <div class="post-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .post-card {
    display: block;
    text-decoration: none;
    border-left-width: 3px;
  }

  .post-card[data-project="climate-stripes"] {
    border-image: linear-gradient(to bottom, #2166ac, #67a9cf, #f7f7f7, #ef8a62, #b2182b) 1;
    border-radius: 0;
  }

  .post-card[data-project="climate-stripes"] .post-title {
    background: linear-gradient(90deg, #2166ac, #67a9cf 25%, #f7f7f7 50%, #ef8a62 75%, #b2182b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    width: fit-content;
  }

  .post-card[data-project="climate-stripes"] .post-tags {
    background: linear-gradient(90deg, #2166ac, #67a9cf 25%, #f7f7f7 50%, #ef8a62 75%, #b2182b);
    -webkit-background-clip: text;
    background-clip: text;
    width: fit-content;
  }

  .post-card[data-project="climate-stripes"] .tag {
    -webkit-text-fill-color: transparent;
    background: none;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .post-title {
    color: var(--accent);
    font-size: 1.15rem;
    margin: 0.3rem 0 0.4rem;
    transition: color 0.2s ease;
  }

  .post-card:hover .post-title {
    color: var(--accent-sky);
  }

  .post-desc {
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
