---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'About' },
  { href: '/projects/', label: 'Projects' },
  { href: '/blog/', label: 'Blog' },
  { href: '/cv/', label: 'CV' },
];

function isActive(href, current) {
  if (href === '/') return current === '/' || current === '';
  return current.startsWith(href);
}
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">Alfie McGlennon</a>
    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a href={link.href} class={isActive(link.href, pathname) ? 'active' : ''}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
