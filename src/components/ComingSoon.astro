---
const { kicker = 'Writing', title = 'Coming soon', body = 'Long-form posts are on the way. Released one at a time.' } = Astro.props;
---

<section class="coming-soon" aria-label={`${kicker}: ${title}`}>
  <div class="cs-stack">
    <p class="cs-kicker">{kicker}</p>
    <h1 class="cs-title">{title}</h1>
    <p class="cs-body">{body}</p>

    <div class="cs-graphic" aria-hidden="true">
      <svg viewBox="0 0 480 220" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="cs-fade" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="currentColor" stop-opacity="0.8" />
            <stop offset="100%" stop-color="currentColor" stop-opacity="0.15" />
          </linearGradient>
        </defs>

        <!-- chart frame -->
        <rect x="20" y="20" width="440" height="180" fill="none" stroke="currentColor" stroke-opacity="0.18" stroke-width="1" />

        <!-- gridlines -->
        <g stroke="currentColor" stroke-opacity="0.07" stroke-width="1">
          <line x1="20" y1="65"  x2="460" y2="65"  />
          <line x1="20" y1="110" x2="460" y2="110" />
          <line x1="20" y1="155" x2="460" y2="155" />
          <line x1="130" y1="20" x2="130" y2="200" />
          <line x1="240" y1="20" x2="240" y2="200" />
          <line x1="350" y1="20" x2="350" y2="200" />
        </g>

        <!-- skeleton bars (already-drafted background) -->
        <g fill="currentColor" fill-opacity="0.08">
          <rect x="30" y="170" width="40" height="20" />
          <rect x="80" y="160" width="40" height="30" />
          <rect x="130" y="140" width="40" height="50" />
          <rect x="180" y="120" width="40" height="70" />
          <rect x="230" y="100" width="40" height="90" />
          <rect x="280" y="85"  width="40" height="105" />
          <rect x="330" y="105" width="40" height="85" />
          <rect x="380" y="130" width="40" height="60" />
        </g>

        <!-- animated sparkline (being drawn) -->
        <path
          class="cs-spark"
          d="M30 180 L80 168 L130 150 L180 128 L230 108 L280 92 L330 110 L380 138 L430 152"
          fill="none"
          stroke="url(#cs-fade)"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />

        <!-- leading-edge dot -->
        <circle class="cs-dot" cx="430" cy="152" r="3.5" fill="currentColor" />
      </svg>
    </div>

    <p class="cs-back">
      <a href="/">&larr; Back to home</a>
    </p>
  </div>
</section>

<style>
  .coming-soon {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  .cs-stack > * + * { margin-top: 1.1rem; }

  .cs-kicker {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--amber);
    margin: 0;
  }

  .cs-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2rem, 4.4vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0.2rem 0 0;
  }

  .cs-body {
    font-family: var(--font-serif);
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--ink-muted);
    max-width: 56ch;
    margin-top: 0.5rem;
  }

  .cs-graphic {
    margin-top: 2.25rem;
    padding: 1rem;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: var(--bg-raised);
    color: var(--teal);
  }

  .cs-graphic svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .cs-spark {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: cs-draw 4s ease-in-out infinite alternate;
  }

  .cs-dot {
    opacity: 0;
    animation: cs-pulse 4s ease-in-out infinite alternate;
  }

  @keyframes cs-draw {
    0%   { stroke-dashoffset: 600; }
    60%  { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes cs-pulse {
    0%, 55%   { opacity: 0; transform: scale(0.6); transform-origin: 430px 152px; }
    65%       { opacity: 1; transform: scale(1.2); transform-origin: 430px 152px; }
    100%      { opacity: 0.85; transform: scale(1); transform-origin: 430px 152px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-spark { stroke-dashoffset: 0; animation: none; }
    .cs-dot { opacity: 0.85; animation: none; }
  }

  .cs-back {
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .cs-back a {
    color: var(--teal-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
  }

  .cs-back a:hover {
    color: var(--amber);
  }
</style>
