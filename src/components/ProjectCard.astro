---
const {
  title,
  description,
  project,
  tags,
  demoUrl,
  sourceUrl,
  blogUrl,
  image,
  status,
} = Astro.props;
---

<article class="project-card card" data-project={project}>
  {image && (
    <div class="project-image">
      <img src={image} alt={`${title} screenshot`} loading="lazy" />
    </div>
  )}
  <div class="project-body">
    <div class="project-head">
      <h3 class="project-title">{title}</h3>
      {status && <span class="project-status">{status}</span>}
    </div>
    <p class="project-desc">{description}</p>
    {tags && tags.length > 0 && (
      <div class="project-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}
    {(demoUrl || sourceUrl || blogUrl) && (
      <div class="project-links">
        {demoUrl && <a href={demoUrl} class="project-link" target="_blank" rel="noopener noreferrer">Live demo &rarr;</a>}
        {sourceUrl && <a href={sourceUrl} class="project-link" target="_blank" rel="noopener noreferrer">Source</a>}
        {blogUrl && <a href={blogUrl} class="project-link">Write-up</a>}
      </div>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .project-image {
    margin: -1.5rem -1.5rem 1.25rem -1.5rem;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
  }

  .project-image img {
    width: 100%;
    border-radius: 0;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.02);
  }

  .project-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-title {
    color: var(--ink);
    font-size: 1.2rem;
    margin: 0;
    font-weight: 600;
  }

  .project-status {
    font-size: 0.72rem;
    font-weight: 500;
    font-family: var(--font-mono);
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.15em 0.55em;
    border-radius: 3px;
    white-space: nowrap;
  }

  .project-desc {
    font-size: 0.96rem;
    color: var(--ink-dim);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--rule);
    padding-top: 1rem;
  }

  .project-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent);
    transition: color 0.2s ease;
  }

  .project-link:hover {
    color: var(--accent-sky);
  }

  /* Climate stripes signature */
  .project-card[data-project="climate-stripes"] .project-title {
    background: linear-gradient(90deg, #2166ac, #67a9cf 25%, #f7f7f7 50%, #ef8a62 75%, #b2182b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
    width: fit-content;
  }
</style>
