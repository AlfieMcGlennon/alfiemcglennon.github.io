---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<Base
  title="Projects"
  description="Selected projects — copula-based compound climate risk, GB grid modelling, RL grid dispatch, quantum ML for weather, and applied climate-data tooling."
>
  <header class="page-head">
    <h1>Projects</h1>
    <p class="lede">
      Applied work at the intersection of climate science, machine learning,
      and operational data &mdash; from copula-based compound risk modelling
      to a browser-based DC power flow tool for the GB transmission network.
    </p>
  </header>

  <section class="block">
    <h2>Dissertation &amp; research</h2>
    <div class="project-grid">
      <ProjectCard
        title="Compound heat stress risk (MSc dissertation)"
        description="A copula-based framework for predicting compound heat stress risk across Europe. Multiplicative decomposition (M_total = M_marginal × M_dependence) separates climate-model error in multivariate extremes — like simultaneous high temperature and high humidity — into a marginal component and a dependence component. The ML angle: XGBoost predicts Kendall's tau dependence from large-scale atmospheric circulation patterns, testing whether ML can correct the dependence structure of climate models directly rather than just bias-correcting the marginals. Targeting two papers: a methods paper on the decomposition, and an ML-driven dependence-estimation paper for the RMetS special issue on ML for Weather and Climate (December 2026 deadline)."
        project="compound-risk"
        status="MSc 2026"
        tags={['copulas', 'XGBoost', 'Kendall’s tau', 'ERA5', 'CMIP6', 'Destination Earth', 'compound extremes']}
      />

      <ProjectCard
        title="Quantum ML for weather and chaotic systems"
        description="Variational quantum circuits (VQCs) applied to ERA5 temperature fields and the Lorenz '63 system using PennyLane. Central finding: Fourier decomposition as an interpretability tool for per-qubit structured VQC regression. Depth sweeps, noise ablations, and Lorenz cross-validation. Documented single-seed limitations and the VQC vs MLP performance gap. Forms the basis of a planned 'Quantum Processes in Weather and Climate' LinkedIn series."
        project="rl-dispatch"
        status="Complete"
        tags={['PennyLane', 'VQC', 'ERA5', 'Lorenz 63', 'Fourier analysis', 'NumPy']}
      />
    </div>
  </section>

  <section class="block">
    <h2>Power-system ML</h2>
    <div class="project-grid">
      <ProjectCard
        title="GB Grid Scenario Tool"
        description="An interactive browser-based DC power flow model of the GB transmission network, built from public NESO data — 27 TNUoS zones, 82 FLOP zones, 43 transmission links, 18 ETYS boundaries. Three dispatch modes including an LP solver compiled to WebAssembly. Weather driven by 34 years of ERA5 reanalysis. Validated against NESO ETYS transfer capabilities (B6F within 2%) and cross-checked with PyPSA-GB. Runs entirely in the browser."
        project="grid-tool"
        tags={['Python', 'Pyomo', 'HiGHS', 'WebAssembly', 'TypeScript', 'Leaflet', 'ERA5', 'NESO', 'ETYS']}
        demoUrl="https://alfiemcglennon.github.io/gb-grid-tool/"
        sourceUrl="https://github.com/AlfieMcGlennon/gb-grid-tool"
        blogUrl="/blog/building-gb-grid-tool/"
        image="/images/grid-tool/hero.png"
      />

      <ProjectCard
        title="RL Grid Dispatch"
        description="PPO reinforcement-learning agents trained to dispatch the GB grid against real network constraints. 9 years of generation data, Elexon wholesale prices, ERA5 weather. Compared MLP, CNN, and 27-zone zonal architectures (448k parameters, 72 ERA5 weather channels). Iterative reward design moved agents from spending £30B/year to within 6% of real grid operations; best agent achieved +12.8% vs NESO baseline with emissions 16% lower than cost-only baseline."
        project="rl-dispatch"
        status="Series in progress"
        tags={['PPO', 'Stable-Baselines3', 'PyTorch', 'CNN', 'SLURM/HPC', 'Elexon', 'ERA5']}
        blogUrl="/blog/rl-grid-dispatch-baseline/"
      />
    </div>
  </section>

  <section class="block">
    <h2>Applied climate tools &amp; data</h2>
    <div class="project-grid">
      <ProjectCard
        title="City Climate Bars &amp; Stripes"
        description="Interactive temperature-anomaly visualisation for 6,000+ cities worldwide, from 1850 to present. Annual and seasonal views, multiple baselines, three colour scaling modes — all running client-side from Berkeley Earth gridded data."
        project="climate-stripes"
        tags={['D3.js', 'Berkeley Earth', 'climate', 'visualisation']}
        demoUrl="https://alfiemcglennon.github.io/city-climate-stripes/"
        sourceUrl="https://github.com/AlfieMcGlennon/city-climate-stripes"
        blogUrl="/blog/city-climate-stripes/"
      />

      <ProjectCard
        title="climate-data-quickstart"
        description="A reproducible quickstart for 14 climate datasets — ERA5 variants, HadCET, CMIP6, UKCP18, GloFAS, Earth Data Hub — built using a three-stage agentic pipeline. Designed to drop you into a working environment for each dataset in minutes rather than days."
        project="compound-risk"
        tags={['xarray', 'cdsapi', 'ERA5', 'CMIP6', 'GloFAS', 'agentic pipelines']}
      />

      <ProjectCard
        title="India electricity demand forecasting"
        description="State-level demand prediction using linear regression, XGBoost, and LSTM with weather variables (ERA5). Temporal cross-validation and per-state R² choropleth mapping. Side-project exploring how far standard ML on weather features can take you for operational demand forecasting."
        project="rl-dispatch"
        tags={['XGBoost', 'LSTM', 'PyTorch', 'ERA5', 'time series', 'choropleth']}
      />

      <ProjectCard
        title="Climate Playbook"
        description="A longer-term project: an interactive climate education and analytics platform for UK Key Stages 1–5 and adult learners, grounded in physically realistic climate representations. MDX-based with modular content; building uncertainty-aware visualisations and simplified modelling tools using ERA5."
        project="grid-tool"
        status="In design"
        tags={['MDX', 'D3.js', 'ERA5', 'climate education']}
      />
    </div>
  </section>

  <section class="block">
    <h2>Writing &amp; analysis</h2>
    <div class="project-grid">
      <ProjectCard
        title="NaFRA flood-risk critique"
        description="A critical analysis of England's National Flood Risk Assessment arguing that institutional rather than technical framing is the core problem — that the headline number understates the operational picture less because of model limitations and more because of how risk is communicated and aggregated."
        project="compound-risk"
        status="Essay"
        tags={['flood risk', 'NaFRA', 'policy', 'analysis']}
      />

      <ProjectCard
        title="CMIP6 ensemble processing on HPC"
        description="31-member IPSL-CM6A-LR historical-run processing pipeline on the University of Reading RACC HPC cluster (gpuscavenger partition). SLURM job arrays, dask-based xarray pipelines for multi-decadal regional analysis."
        project="rl-dispatch"
        status="Internal"
        tags={['CMIP6', 'IPSL-CM6A-LR', 'SLURM', 'xarray', 'dask']}
      />

      <ProjectCard
        title="Local RAG for dissertation research"
        description="A local retrieval-augmented-generation system for dissertation literature: SSE streaming, agentic multi-hop retrieval over a Zotero + Obsidian corpus. Internal tooling, not productised."
        project="rl-dispatch"
        status="Internal"
        tags={['RAG', 'SSE', 'agentic retrieval', 'Zotero', 'Obsidian']}
      />
    </div>
  </section>
</Base>

<style>
  .page-head {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1rem;
  }

  .block {
    padding: 1.75rem 0;
  }

  .block h2 {
    font-size: 1.3rem;
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--ink);
  }

  .project-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
</style>
