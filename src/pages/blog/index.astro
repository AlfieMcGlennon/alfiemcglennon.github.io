---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<Base title="Blog" description="Technical write-ups on compound climate risk, power-system ML, and applied climate data.">
  <header class="page-head">
    <h1>Blog</h1>
    <p class="lede">
      Technical write-ups and project notes &mdash; compound climate risk,
      reinforcement learning for power systems, and applied climate data.
    </p>
  </header>

  {posts.length === 0 ? (
    <div class="empty-state">
      <p>Posts coming soon. First up: building the GB Grid Scenario Tool.</p>
    </div>
  ) : (
    <div class="posts-list">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          project={post.data.project}
          tags={post.data.tags}
        />
      ))}
    </div>
  )}
</Base>

<style>
  .page-head {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 2rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .empty-state {
    margin-top: 3rem;
    padding: 2rem;
    text-align: center;
    border: 1px dashed var(--rule);
    border-radius: 8px;
  }

  .empty-state p {
    color: var(--ink-faint);
  }
</style>
