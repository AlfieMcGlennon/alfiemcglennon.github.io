---
import Base from '../../layouts/Base.astro';
import ComingSoon from '../../components/ComingSoon.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

function fmt(d) {
  return new Date(d).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base
  title="Writing | Alfie McGlennon"
  description="Long-form writing on climate risk, the GB grid environment, RL dispatch, quantum ML, and climate data visualisation. Coming soon."
  ogTitle="Writing | Alfie McGlennon"
  ogDescription="Long-form posts coming soon."
>
  {posts.length === 0 ? (
    <ComingSoon
      kicker="Writing"
      title="Coming soon"
      body="Long-form posts on the work behind the projects: copulas in climate risk, the GB grid environment, RL dispatch, quantum ML, and climate data visualisation. Released one at a time."
    />
  ) : (
    <article class="page writing-index">
      <header class="writing-head">
        <p class="kicker">Writing</p>
        <h1>Long-form</h1>
        <p class="lede">
          Full project write-ups, the thinking behind them, and occasional
          blog posts on methods and ideas.
        </p>
      </header>

      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <a href={`/writing/${post.id}/`} class="post-link">
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-meta">
                <time datetime={new Date(post.data.date).toISOString()}>{fmt(post.data.date)}</time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <>
                    <span class="sep">·</span>
                    <span class="post-tags">{post.data.tags.join(' · ')}</span>
                  </>
                )}
              </p>
              <p class="post-desc">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </article>
  )}
</Base>

<style>
  .writing-head {
    margin-bottom: 2.5rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    margin: 0;
    border-top: 1px solid var(--rule);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .post-link {
    display: block;
    padding: 1.75rem 0;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 0;
    transition: background 0.2s ease;
  }

  .post-link:hover {
    background: var(--bg-raised);
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: 1.32rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.4rem;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-link:hover .post-title {
    color: var(--teal);
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-muted);
    margin: 0 0 0.5rem;
    line-height: 1.55;
  }

  .post-meta .sep {
    color: var(--ink-faint);
    margin: 0 0.4rem;
  }

  .post-desc {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-muted);
    margin: 0;
  }
</style>
