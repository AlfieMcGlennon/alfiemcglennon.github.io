  }

  .other-research {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.25rem 0;
    color: var(--ink-muted);
    font-family: var(--font-serif);
  }

  .other-research p {
    margin: 0;
    font-size: 1rem;
    color: var(--ink-muted);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
    flex-shrink: 0;
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; opacity: 0.7; }
  }

  /* Inline equation block: smaller and centred */
  .research :global(pre) {
    text-align: center;
    background: var(--bg-raised);
    border-left: 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.1rem 1rem;
    border-radius: 0;
  }

  .research :global(pre code) {
    font-size: 1.05rem;
    color: var(--teal-deep);
  }
</style>
