---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero: animated atmospheric sky, reflects live Reading weather where the API is reachable -->
  <section class="hero" data-hero aria-label="Introduction">
    <div class="sky" aria-hidden="true">
      <svg
        class="sky-svg"
        viewBox="0 0 1200 600"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <linearGradient id="sky-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" class="sky-stop-top" />
            <stop offset="55%" class="sky-stop-mid" />
            <stop offset="100%" class="sky-stop-bot" />
          </linearGradient>
          <filter id="cloud-blur" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="5" />
          </filter>
          <symbol id="cloud-a" viewBox="0 0 320 100">
            <ellipse cx="80" cy="60" rx="80" ry="26" fill="#ffffff" />
            <ellipse cx="160" cy="48" rx="100" ry="32" fill="#ffffff" />
            <ellipse cx="240" cy="62" rx="74" ry="22" fill="#ffffff" />
          </symbol>
          <symbol id="cloud-b" viewBox="0 0 260 90">
            <ellipse cx="70" cy="55" rx="70" ry="22" fill="#ffffff" />
            <ellipse cx="150" cy="44" rx="80" ry="28" fill="#ffffff" />
            <ellipse cx="210" cy="58" rx="50" ry="18" fill="#ffffff" />
          </symbol>
          <symbol id="cloud-c" viewBox="0 0 200 70">
            <ellipse cx="60" cy="40" rx="56" ry="18" fill="#ffffff" />
            <ellipse cx="130" cy="34" rx="62" ry="22" fill="#ffffff" />
          </symbol>
          <pattern id="rain-pattern" x="0" y="0" width="60" height="100" patternUnits="userSpaceOnUse" patternTransform="rotate(15)">
            <line x1="10" y1="0" x2="10" y2="22" stroke="#7a8896" stroke-width="1.1" stroke-linecap="round" opacity="0.7" />
            <line x1="34" y1="40" x2="34" y2="64" stroke="#7a8896" stroke-width="1.1" stroke-linecap="round" opacity="0.55" />
            <line x1="50" y1="70" x2="50" y2="90" stroke="#7a8896" stroke-width="1.1" stroke-linecap="round" opacity="0.6" />
          </pattern>
        </defs>

        <rect width="1200" height="600" fill="url(#sky-gradient)" />

        <g class="cloud-layer cloud-layer-slow" filter="url(#cloud-blur)">
          <use href="#cloud-a" x="-400" y="80" width="320" height="100" opacity="0.55" />
          <use href="#cloud-c" x="200" y="130" width="200" height="70" opacity="0.45" />
          <use href="#cloud-b" x="700" y="60" width="260" height="90" opacity="0.55" />
          <use href="#cloud-a" x="1100" y="110" width="320" height="100" opacity="0.5" />
        </g>

        <g class="cloud-layer cloud-layer-medium" filter="url(#cloud-blur)">
          <use href="#cloud-b" x="-300" y="220" width="260" height="90" opacity="0.7" />
          <use href="#cloud-a" x="350" y="250" width="320" height="100" opacity="0.6" />
          <use href="#cloud-c" x="900" y="200" width="200" height="70" opacity="0.7" />
        </g>

        <g class="cloud-layer cloud-layer-fast" filter="url(#cloud-blur)">
          <use href="#cloud-c" x="-200" y="400" width="200" height="70" opacity="0.75" />
          <use href="#cloud-b" x="500" y="430" width="260" height="90" opacity="0.7" />
          <use href="#cloud-a" x="950" y="410" width="320" height="100" opacity="0.7" />
        </g>

        <rect class="rain-layer" width="1200" height="600" fill="url(#rain-pattern)" />
      </svg>
    </div>

    <div class="hero-content">
      <h1 class="hero-name">Alfie McGlennon</h1>
      <p class="hero-affiliation">MSc Climate Change &amp; AI // University of Reading</p>
      <p class="hero-tag">
        Climate science, machine learning, and compound risk. From
        copula-based dependence modelling to reinforcement learning on the
        national grid.
      </p>
    </div>

    <p class="weather-attr" data-weather-attr>
      <span data-weather-summary>Live conditions</span> at Reading, UK
      &middot;
      <a href="https://open-meteo.com" target="_blank" rel="noopener noreferrer">Open-Meteo</a>
    </p>
  </section>

  <script>
    (async function initWeatherHero() {
      const hero = document.querySelector('[data-hero]');
      if (!hero) return;

      const CACHE_KEY = 'weather-reading-v1';
      const TTL_MS = 30 * 60 * 1000;
      const URL = 'https://api.open-meteo.com/v1/forecast?latitude=51.4543&longitude=-0.9781&current=temperature_2m,relative_humidity_2m,wind_speed_10m,cloud_cover,weather_code,is_day&timezone=Europe/London';

      const codeToLabel = (c, isDay) => {
        if (c === 0) return isDay ? 'Clear sky' : 'Clear night';
        if (c === 1) return 'Mostly clear';
        if (c === 2) return 'Partly cloudy';
        if (c === 3) return 'Overcast';
        if (c === 45 || c === 48) return 'Fog';
        if (c >= 51 && c <= 57) return 'Drizzle';
        if (c >= 61 && c <= 67) return 'Rain';
        if (c >= 71 && c <= 77) return 'Snow';
        if (c >= 80 && c <= 82) return 'Rain showers';
        if (c === 85 || c === 86) return 'Snow showers';
        if (c >= 95 && c <= 99) return 'Thunderstorm';
        return 'Live conditions';
      };

      function applyWeather(payload) {
        const c = payload.current || payload;
        const code = c.weather_code ?? 2;
        const isDay = c.is_day ?? 1;
        const cloudCover = c.cloud_cover ?? 50;
        const windSpeed = c.wind_speed_10m ?? 10;
        const temp = c.temperature_2m ?? 15;

        let state = 'partly-cloudy';
        if (isDay === 0) state = 'night';
        else if (code === 0 || code === 1) state = 'clear';
        else if (code === 2) state = 'partly-cloudy';
        else if (code === 3 || code === 45 || code === 48) state = 'overcast';
        else if ((code >= 51 && code <= 67) || (code >= 80 && code <= 82)) state = 'rain';
        else if ((code >= 71 && code <= 77) || code === 85 || code === 86) state = 'snow';
        else if (code >= 95 && code <= 99) state = 'storm';
        hero.dataset.weather = state;

        let density = 'mid';
        if (cloudCover < 25) density = 'low';
        else if (cloudCover > 70) density = 'high';
        hero.dataset.cloudDensity = density;

        let speed = 'mid';
        if (windSpeed < 10) speed = 'slow';
        else if (windSpeed > 30) speed = 'fast';
        hero.dataset.windSpeed = speed;

        let warmth = 'neutral';
        if (temp < 5) warmth = 'cool';
        else if (temp > 25) warmth = 'warm';
        hero.dataset.warmth = warmth;

        hero.classList.add('weather-live');
        const summary = hero.querySelector('[data-weather-summary]');
        if (summary) summary.textContent = `${codeToLabel(code, isDay)}, ${Math.round(temp)}°C`;
      }

      try {
        const cached = sessionStorage.getItem(CACHE_KEY);
        if (cached) {
          const parsed = JSON.parse(cached);
          if (Date.now() - parsed.timestamp < TTL_MS) {
            applyWeather(parsed.data);
            return;
          }
        }
      } catch (e) { /* ignore */ }

      try {
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), 2000);
        const res = await fetch(URL, { signal: controller.signal });
        clearTimeout(timer);
        if (!res.ok) throw new Error('bad response');
        const data = await res.json();
        try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ data, timestamp: Date.now() })); } catch (e) { /* ignore quota */ }
        applyWeather(data);
      } catch (e) {
        // Silent fallback: hero stays on default sky.
      }
    })();
  </script>

  <!-- About -->
  <section class="page about">
    <div class="about-grid">
      <div class="about-text">
        <p>
          I&rsquo;m finishing an MSc in Climate Change and AI at the
          University of Reading, after a BSc in Meteorology and Climate in
          the same department. I got hooked on the gap between what climate
          models simulate and what actually happens on the ground,
          particularly for compound events where multiple hazards arrive
          together. My dissertation focuses on compound heat stress across
          Europe: when heat and humidity combine in ways that neither
          variable alone would predict. I&rsquo;m trying to work out where
          climate models get the dependence wrong, and whether machine
          learning can fix it directly.
        </p>
        <p>
          I was drawn to reinforcement learning through the visually
          compelling demos of agents learning to drive cars or play games. I
          wanted to test it on something I understood. Weather and climate
          systems do not map cleanly to the typical RL framing, but energy
          grids, where weather is a core input, were a much better fit. So
          I started building an RL environment for GB electricity dispatch.
          The scope kept growing. What began as &lsquo;can an agent learn
          merit order?&rsquo; turned into a serious exercise in data
          assimilation from public sources, and a test of how far you can
          get with human-led architecture and AI execution. The
          <a href="/projects/">GB Grid Scenario Tool</a> ended up as a
          validated DC power flow model of the transmission network, and
          the RL agents trained on top of it went from spending £30 billion
          a year to within 6% of real grid costs. Alongside that, the
          <a href="/writing/copulas-compound-risk/">copula explainer</a> I
          wrote for my own understanding turned into an interactive visual
          guide. I get hooked on problems and follow them further than the
          brief asks for.
        </p>
        <p>
          I&rsquo;m targeting roles in climate risk analytics, reinsurance
          (Swiss Re and Munich Re type work), or operational meteorology
          (ECMWF-adjacent). Based in the Reading area. The through-line
          across all my work is applying statistical and machine-learning
          methods to climate and weather data where the outputs have
          operational or commercial value.
        </p>
      </div>

      <!-- TODO: replace src below with the actual photo path once supplied (e.g. /images/alfie.jpg) -->
      <figure class="about-photo" aria-hidden="true">
        <div class="photo-placeholder">
          <span>Photo</span>
        </div>
      </figure>
    </div>
  </section>

  <!-- Jump-to cards -->
  <section class="page jump">
    <ul class="jump-cards">
      <li>
        <a href="/research/" class="jump-card">
          <p class="jump-card-label">Research</p>
          <p class="jump-card-line">Compound heat stress, copulas, and where climate models go wrong.</p>
        </a>
      </li>
      <li>
        <a href="/projects/" class="jump-card">
          <p class="jump-card-label">Projects</p>
          <p class="jump-card-line">Grid dispatch, quantum ML, climate data tooling, and more.</p>
        </a>
      </li>
      <li>
        <a href="/writing/" class="jump-card">
          <p class="jump-card-label">Writing</p>
          <p class="jump-card-line">Long-form posts on copulas, grid dispatch, RL, and climate data.</p>
        </a>
      </li>
      <li>
        <a href="https://alfiemcglennon.github.io/gb-grid-tool/" class="jump-card" target="_blank" rel="noopener noreferrer">
          <p class="jump-card-label">Grid Tool demo</p>
          <p class="jump-card-line">An interactive transmission grid model of GB, in the browser.</p>
        </a>
      </li>
      <li>
        <a href="https://github.com/AlfieMcGlennon" class="jump-card" target="_blank" rel="noopener noreferrer">
          <p class="jump-card-label">GitHub</p>
          <p class="jump-card-line">Open-source work and side projects.</p>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/alfred-mcglennon-927589253/" class="jump-card" target="_blank" rel="noopener noreferrer">
          <p class="jump-card-label">LinkedIn</p>
          <p class="jump-card-line">Career history and longer posts.</p>
        </a>
      </li>
    </ul>
  </section>
</Base>

<style>
  /* ── Hero (weather-aware) ──────────────────────────── */

  .hero {
    position: relative;
    width: 100%;
    height: clamp(440px, 75vh, 640px);
    overflow: hidden;
    border-bottom: 1px solid var(--rule);

    /* Default (partly-cloudy) sky stops. Weather classes override. */
    --sky-top: #d8e8eb;
    --sky-mid: #ece8dc;
    --sky-bot: #f3e1c8;

    --cloud-density: 1;
    --cloud-speed-mult: 1;
    --rain-opacity: 0;

    transition: background 0.6s ease;
  }

  .sky-stop-top { stop-color: var(--sky-top); }
  .sky-stop-mid { stop-color: var(--sky-mid); }
  .sky-stop-bot { stop-color: var(--sky-bot); }

  /* Weather states */
  .hero[data-weather="clear"] {
    --sky-top: #c8dde8;
    --sky-mid: #f0e6cf;
    --sky-bot: #f6d4a0;
  }
  .hero[data-weather="partly-cloudy"] {
    --sky-top: #d8e8eb;
    --sky-mid: #ece8dc;
    --sky-bot: #f3e1c8;
  }
  .hero[data-weather="overcast"] {
    --sky-top: #b8c2c6;
    --sky-mid: #c8cdce;
    --sky-bot: #d4d4ce;
  }
  .hero[data-weather="rain"] {
    --sky-top: #8b95a3;
    --sky-mid: #9ea3ab;
    --sky-bot: #b4b2a8;
    --rain-opacity: 0.14;
  }
  .hero[data-weather="snow"] {
    --sky-top: #d8e4ed;
    --sky-mid: #e8eaec;
    --sky-bot: #ecebe3;
  }
  .hero[data-weather="storm"] {
    --sky-top: #4a525c;
    --sky-mid: #6a6e75;
    --sky-bot: #847f7a;
    --rain-opacity: 0.18;
  }
  .hero[data-weather="night"] {
    --sky-top: #14222c;
    --sky-mid: #1d3540;
    --sky-bot: #213038;
  }

  /* Temperature shift (subtle warmth at horizon) */
  .hero[data-warmth="warm"][data-weather="clear"] { --sky-bot: #f0bf80; }
  .hero[data-warmth="warm"][data-weather="partly-cloudy"] { --sky-bot: #efc995; }
  .hero[data-warmth="cool"][data-weather="clear"] { --sky-bot: #d6dbd8; }
  .hero[data-warmth="cool"][data-weather="partly-cloudy"] { --sky-bot: #dadcd0; }

  /* Cloud density (parent group opacity multiplier) */
  .hero[data-cloud-density="low"] .cloud-layer { opacity: 0.55; }
  .hero[data-cloud-density="high"] .cloud-layer { opacity: 1.15; }

  /* Wind speed */
  .hero[data-wind-speed="slow"] { --cloud-speed-mult: 1.4; }
  .hero[data-wind-speed="fast"] { --cloud-speed-mult: 0.55; }

  /* Rain pattern overlay */
  .rain-layer {
    opacity: var(--rain-opacity, 0);
    transition: opacity 0.6s ease;
  }

  .sky {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .sky-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cloud-layer {
    transform-origin: center;
    will-change: transform;
    transition: opacity 0.6s ease;
  }

  .cloud-layer-slow {
    animation: drift-slow calc(180s * var(--cloud-speed-mult)) linear infinite alternate;
  }
  .cloud-layer-medium {
    animation: drift-medium calc(120s * var(--cloud-speed-mult)) linear infinite alternate;
  }
  .cloud-layer-fast {
    animation: drift-fast calc(80s * var(--cloud-speed-mult)) linear infinite alternate;
  }

  @keyframes drift-slow {
    from { transform: translateX(-8%); }
    to   { transform: translateX(8%); }
  }
  @keyframes drift-medium {
    from { transform: translateX(-12%); }
    to   { transform: translateX(12%); }
  }
  @keyframes drift-fast {
    from { transform: translateX(-18%); }
    to   { transform: translateX(18%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cloud-layer { animation: none; }
  }

  /* Attribution, shown only when live weather is applied */
  .weather-attr {
    position: absolute;
    right: 1rem;
    bottom: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-muted);
    opacity: 0;
    transition: opacity 0.4s ease;
    margin: 0;
    pointer-events: none;
    z-index: 2;
  }
  .hero.weather-live .weather-attr {
    opacity: 0.55;
    pointer-events: auto;
  }
  .weather-attr a {
    color: inherit;
    border-bottom: 0;
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 2px;
  }
  .weather-attr a:hover { color: var(--teal); }

  /* When night sky, lift hero text for contrast */
  .hero[data-weather="night"] .hero-name,
  .hero[data-weather="storm"] .hero-name { color: #f3efe9; }
  .hero[data-weather="night"] .hero-affiliation,
  .hero[data-weather="storm"] .hero-affiliation { color: #9bd0c8; }
  .hero[data-weather="night"] .hero-tag,
  .hero[data-weather="storm"] .hero-tag { color: #d6d1c4; }
  .hero[data-weather="night"] .weather-attr,
  .hero[data-weather="storm"] .weather-attr { color: #c8c4ba; }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 1.5rem;
    max-width: 920px;
    margin: 0 auto;
    text-align: left;
  }

  .hero-name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink);
    margin-bottom: 0.85rem;
  }

  .hero-affiliation {
    font-family: var(--font-mono);
    font-size: clamp(0.85rem, 1.4vw, 1rem);
    color: var(--teal-deep);
    margin-bottom: 0.85rem;
    letter-spacing: 0.01em;
  }

  .hero-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    color: var(--ink-dim);
    max-width: 42ch;
    line-height: 1.45;
  }

  /* ── About ────────────────────────────────────────── */

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    align-items: start;
  }

  @media (min-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr 200px;
      gap: 2.5rem;
    }
  }

  .about-photo {
    margin: 0;
    width: 100%;
    max-width: 220px;
  }

  .photo-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-faint);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  /* ── Jump cards ───────────────────────────────────── */

  .jump {
    padding-top: 0;
  }

  .jump-cards {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule);
  }

  @media (min-width: 560px) {
    .jump-cards { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 900px) {
    .jump-cards { grid-template-columns: 1fr 1fr 1fr; }
  }

  .jump-card {
    display: block;
    padding: 1.5rem 0.25rem;
    border-bottom: 1px solid var(--rule);
    color: var(--ink);
    text-decoration: none;
    border-left: 0;
    border-right: 0;
    background: none;
    transition: background 0.2s ease;
  }

  .jump-card:hover {
    background: var(--bg-raised);
  }

  @media (min-width: 560px) and (max-width: 899px) {
    .jump-cards li:nth-child(odd) .jump-card { padding-right: 1.5rem; }
    .jump-cards li:nth-child(even) .jump-card { padding-left: 1.5rem; border-left: 1px solid var(--rule); }
  }

  @media (min-width: 900px) {
    .jump-cards li .jump-card { padding-left: 1.25rem; padding-right: 1.25rem; border-left: 1px solid var(--rule); }
    .jump-cards li:nth-child(3n+1) .jump-card { padding-left: 0.25rem; border-left: 0; }
  }

  .jump-card-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--teal-deep);
    margin: 0 0 0.3rem;
  }

  .jump-card:hover .jump-card-label {
    color: var(--amber);
  }

  .jump-card-line {
    font-family: var(--font-serif);
    font-size: 0.98rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.55;
  }
</style>
