---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero: animated atmospheric sky, reflects live Reading weather where the API is reachable -->
  <section class="hero" data-hero aria-label="Introduction">
    <div class="sky" aria-hidden="true">
      <svg
        class="sky-svg"
        viewBox="0 0 1200 600"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <linearGradient id="sky-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" class="sky-stop-top" />
            <stop offset="55%" class="sky-stop-mid" />
            <stop offset="100%" class="sky-stop-bot" />
          </linearGradient>
          <filter id="cloud-blur" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="5" />
          </filter>
          <symbol id="cloud-a" viewBox="0 0 320 100">
            <ellipse cx="80" cy="60" rx="80" ry="26" fill="#ffffff" />
            <ellipse cx="160" cy="48" rx="100" ry="32" fill="#ffffff" />
            <ellipse cx="240" cy="62" rx="74" ry="22" fill="#ffffff" />
          </symbol>
          <symbol id="cloud-b" viewBox="0 0 260 90">
            <ellipse cx="70" cy="55" rx="70" ry="22" fill="#ffffff" />
            <ellipse cx="150" cy="44" rx="80" ry="28" fill="#ffffff" />
            <ellipse cx="210" cy="58" rx="50" ry="18" fill="#ffffff" />
          </symbol>
          <symbol id="cloud-c" viewBox="0 0 200 70">
            <ellipse cx="60" cy="40" rx="56" ry="18" fill="#ffffff" />
            <ellipse cx="130" cy="34" rx="62" ry="22" fill="#ffffff" />
          </symbol>
          <pattern id="rain-pattern" x="0" y="0" width="60" height="100" patternUnits="userSpaceOnUse" patternTransform="rotate(15)">
            <line x1="10" y1="0" x2="10" y2="22" stroke="#7a8896" stroke-width="1.1" stroke-linecap="round" opacity="0.7" />
            <line x1="34" y1="40" x2="34" y2="64" stroke="#7a8896" stroke-width="1.1" stroke-linecap="round" opacity="0.55" />
            <line x1="50" y1="70" x2="50" y2="90" stroke="#7a8896" stroke-width="1.1" stroke-linecap="round" opacity="0.6" />
          </pattern>
        </defs>

        <rect width="1200" height="600" fill="url(#sky-gradient)" />

        <g class="cloud-layer cloud-layer-slow" filter="url(#cloud-blur)">
          <use href="#cloud-a" x="-400" y="80" width="320" height="100" opacity="0.55" />
          <use href="#cloud-c" x="200" y="130" width="200" height="70" opacity="0.45" />
          <use href="#cloud-b" x="700" y="60" width="260" height="90" opacity="0.55" />
          <use href="#cloud-a" x="1100" y="110" width="320" height="100" opacity="0.5" />
        </g>

        <g class="cloud-layer cloud-layer-medium" filter="url(#cloud-blur)">
          <use href="#cloud-b" x="-300" y="220" width="260" height="90" opacity="0.7" />
          <use href="#cloud-a" x="350" y="250" width="320" height="100" opacity="0.6" />
          <use href="#cloud-c" x="900" y="200" width="200" height="70" opacity="0.7" />
        </g>

        <g class="cloud-layer cloud-layer-fast" filter="url(#cloud-blur)">
          <use href="#cloud-c" x="-200" y="400" width="200" height="70" opacity="0.75" />
          <use href="#cloud-b" x="500" y="430" width="260" height="90" opacity="0.7" />
          <use href="#cloud-a" x="950" y="410" width="320" height="100" opacity="0.7" />
        </g>

        <rect class="rain-layer" width="1200" height="600" fill="url(#rain-pattern)" />
      </svg>
    </div>

    <div class="hero-content">
      <h1 class="hero-name">Alfie McGlennon</h1>
      <p class="hero-affiliation">MSc Climate Change &amp; AI // University of Reading</p>
      <p class="hero-tag">
        Climate science, machine learning, quantum, and compound risk.
        From copula-based dependence modelling to reinforcement learning on
        the national grid.
      </p>
    </div>

    <div class="weather-readout" data-weather-readout aria-label="Live weather telemetry">
      <span class="wr-dot" aria-hidden="true"></span>
      <span class="wr-label">LIVE</span>
      <span class="wr-sep" aria-hidden="true">&middot;</span>
      <span class="wr-loc">READING</span>
      <span class="wr-sep" aria-hidden="true">&middot;</span>
      <span class="wr-segment" data-readout-temp>--.-&deg;C</span>
      <span class="wr-sep wr-sep-rh" aria-hidden="true">&middot;</span>
      <span class="wr-segment wr-rh" data-readout-rh>-- %RH</span>
      <span class="wr-sep" aria-hidden="true">&middot;</span>
      <span class="wr-segment wr-cond" data-readout-cond>&hellip;</span>
      <span class="wr-sep wr-sep-time" aria-hidden="true">&middot;</span>
      <span class="wr-segment wr-time" data-readout-time>UPDATED --:--</span>
      <span class="wr-sep" aria-hidden="true">&middot;</span>
      <a class="wr-link" href="https://open-meteo.com" target="_blank" rel="noopener noreferrer">OPEN-METEO</a>
    </div>
  </section>

  <script>
    (async function initWeatherHero() {
      const hero = document.querySelector('[data-hero]');
      if (!hero) return;

      const CACHE_KEY = 'weather-reading-v1';
      const TTL_MS = 30 * 60 * 1000;
      const URL = 'https://api.open-meteo.com/v1/forecast?latitude=51.4543&longitude=-0.9781&current=temperature_2m,relative_humidity_2m,wind_speed_10m,cloud_cover,weather_code,is_day&timezone=Europe/London';

      const codeToLabel = (c, isDay) => {
        if (c === 0) return isDay ? 'CLEAR SKY' : 'CLEAR NIGHT';
        if (c === 1) return 'MOSTLY CLEAR';
        if (c === 2) return 'PARTLY CLOUDY';
        if (c === 3) return 'OVERCAST';
        if (c === 45 || c === 48) return 'FOG';
        if (c >= 51 && c <= 57) return 'DRIZZLE';
        if (c >= 61 && c <= 67) return 'RAIN';
        if (c >= 71 && c <= 77) return 'SNOW';
        if (c >= 80 && c <= 82) return 'RAIN SHOWERS';
        if (c === 85 || c === 86) return 'SNOW SHOWERS';
        if (c >= 95 && c <= 99) return 'THUNDERSTORM';
        return 'LIVE';
      };

      function fmtClock(d) {
        return d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZone: 'Europe/London' });
      }

      function applyWeather(payload) {
        const c = payload.current || payload;
        const code = c.weather_code ?? 2;
        const isDay = c.is_day ?? 1;
        const cloudCover = c.cloud_cover ?? 50;
        const windSpeed = c.wind_speed_10m ?? 10;
        const temp = c.temperature_2m ?? 15;

        let state = 'partly-cloudy';
        if (isDay === 0) state = 'night';
        else if (code === 0 || code === 1) state = 'clear';
        else if (code === 2) state = 'partly-cloudy';
        else if (code === 3 || code === 45 || code === 48) state = 'overcast';
        else if ((code >= 51 && code <= 67) || (code >= 80 && code <= 82)) state = 'rain';
        else if ((code >= 71 && code <= 77) || code === 85 || code === 86) state = 'snow';
        else if (code >= 95 && code <= 99) state = 'storm';
        hero.dataset.weather = state;

        let density = 'mid';
        if (cloudCover < 25) density = 'low';
        else if (cloudCover > 70) density = 'high';
        hero.dataset.cloudDensity = density;

        let speed = 'mid';
        if (windSpeed < 10) speed = 'slow';
        else if (windSpeed > 30) speed = 'fast';
        hero.dataset.windSpeed = speed;

        let warmth = 'neutral';
        if (temp < 5) warmth = 'cool';
        else if (temp > 25) warmth = 'warm';
        hero.dataset.warmth = warmth;

        hero.classList.add('weather-live');

        const humidity = c.relative_humidity_2m ?? null;
        const fetchedAt = payload.fetchedAt ? new Date(payload.fetchedAt) : new Date();

        const tempEl = hero.querySelector('[data-readout-temp]');
        const rhEl = hero.querySelector('[data-readout-rh]');
        const condEl = hero.querySelector('[data-readout-cond]');
        const timeEl = hero.querySelector('[data-readout-time]');

        if (tempEl) tempEl.textContent = `${temp.toFixed(1)}°C`;
        if (rhEl) rhEl.textContent = humidity != null ? `${Math.round(humidity)} %RH` : '— %RH';
        if (condEl) condEl.textContent = codeToLabel(code, isDay);
        if (timeEl) timeEl.textContent = `UPDATED ${fmtClock(fetchedAt)}`;
      }

      try {
        const cached = sessionStorage.getItem(CACHE_KEY);
        if (cached) {
          const parsed = JSON.parse(cached);
          if (Date.now() - parsed.timestamp < TTL_MS) {
            applyWeather({ ...parsed.data, fetchedAt: parsed.timestamp });
            return;
          }
        }
      } catch (e) { /* ignore */ }

      try {
        const controller = new AbortController();
        const timer = setTimeout(() => controller.abort(), 2000);
        const res = await fetch(URL, { signal: controller.signal });
        clearTimeout(timer);
        if (!res.ok) throw new Error('bad response');
        const data = await res.json();
        const fetchedAt = Date.now();
        try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ data, timestamp: fetchedAt })); } catch (e) { /* ignore quota */ }
        applyWeather({ ...data, fetchedAt });
      } catch (e) {
        // Silent fallback: hero stays on default sky.
      }
    })();
  </script>

  <!-- About -->
  <section class="page about">
    <div class="about-grid">
      <div class="about-text">
        <p>
          Hi, I&rsquo;m Alfie. I&rsquo;m finishing an MSc in Climate Change
          and AI at the University of Reading, after a BSc in Meteorology
          and Climate in the same department. I love a good problem and
          trying to understand things through a data lens. My dissertation
          focuses on compound heat stress across Europe: when heat and
          humidity combine in ways that neither variable alone would
          predict.
        </p>
        <p>
          I&rsquo;m curious about how things work and why they work the way
          they do, whether that&rsquo;s atmospheric systems, energy markets,
          social structures, or the assumptions buried inside a model. Data
          is usually how I pull those questions apart. My university and
          personal work spans machine learning, reinforcement learning,
          quantum computing, and statistical climatology. Lately I&rsquo;ve
          been working with more hands-off workflows: I design the research
          brief, the data pipeline, and the architecture, and use AI tools
          to build the code and front-end around it.
          <a href="/projects/">Projects</a> has the builds.
          <a href="/writing/">Writing</a> has the full write-ups.
        </p>
        <p>
          If you work in climate risk, reinsurance, operational
          meteorology, or anywhere that statistical and ML methods meet
          real-world data, I&rsquo;d like to hear from you. Based in the
          Reading area.
        </p>
      </div>

      <figure class="about-photo">
        <img
          src="/images/alfie.jpg"
          alt="Alfie McGlennon"
          width="220"
          height="275"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <!-- Jump-to cards -->
  <section class="page jump">
    <ul class="jump-cards">
      <li>
        <a href="/research/" class="jump-card">
          <p class="jump-card-label">Research</p>
          <p class="jump-card-line">Compound heat stress and copula-based risk.</p>
        </a>
      </li>
      <li>
        <a href="/projects/" class="jump-card">
          <p class="jump-card-label">Projects</p>
          <p class="jump-card-line">Grid dispatch, quantum ML, climate tooling.</p>
        </a>
      </li>
      <li>
        <a href="/writing/" class="jump-card">
          <p class="jump-card-label">Writing</p>
          <p class="jump-card-line">Full project write-ups, and the thinking behind them.</p>
        </a>
      </li>
      <li>
        <a href="https://alfiemcglennon.github.io/gb-grid-tool/" class="jump-card" target="_blank" rel="noopener noreferrer">
          <p class="jump-card-label">Grid Tool demo</p>
          <p class="jump-card-line">Browser-based GB transmission grid model.</p>
        </a>
      </li>
      <li>
        <a href="https://github.com/AlfieMcGlennon" class="jump-card" target="_blank" rel="noopener noreferrer">
          <p class="jump-card-label">GitHub</p>
          <p class="jump-card-line">Open-source builds and side projects.</p>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/alfred-mcglennon-927589253/" class="jump-card" target="_blank" rel="noopener noreferrer">
          <p class="jump-card-label">LinkedIn</p>
          <p class="jump-card-line">Career history and longer-form posts.</p>
        </a>
      </li>
    </ul>
  </section>
</Base>

<style>
  /* ── Hero (weather-aware) ──────────────────────────── */

  .hero {
    position: relative;
    width: 100%;
    height: clamp(340px, 58vh, 520px);
    overflow: hidden;
    border-bottom: 1px solid var(--rule);

    /* Default (partly-cloudy) sky stops. Weather classes override. */
    --sky-top: #b6cfdc;
    --sky-mid: #e8d4a8;
    --sky-bot: #ecb37a;

    --cloud-density: 1;
    --cloud-speed-mult: 1;
    --rain-opacity: 0;
    --sun-opacity: 1;

    transition: background 0.6s ease;
  }

  /* Sun glow, hidden by weather states that override --sun-opacity */
  .hero::before {
    content: '';
    position: absolute;
    top: 6%;
    right: 10%;
    width: clamp(220px, 32vw, 380px);
    height: clamp(220px, 32vw, 380px);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 218, 150, 0.65) 0%,
      rgba(255, 200, 130, 0.32) 35%,
      rgba(255, 200, 130, 0) 70%
    );
    pointer-events: none;
    z-index: 0;
    opacity: var(--sun-opacity, 1);
    transition: opacity 0.6s ease;
    will-change: opacity;
  }


  .sky-stop-top { stop-color: var(--sky-top); }
  .sky-stop-mid { stop-color: var(--sky-mid); }
  .sky-stop-bot { stop-color: var(--sky-bot); }

  /* Weather states */
  .hero[data-weather="clear"] {
    --sky-top: #9ec4dc;
    --sky-mid: #f0d4a0;
    --sky-bot: #f3b270;
    --sun-opacity: 1;
  }
  .hero[data-weather="partly-cloudy"] {
    --sky-top: #b6cfdc;
    --sky-mid: #e8d4a8;
    --sky-bot: #ecb37a;
    --sun-opacity: 0.85;
  }
  .hero[data-weather="overcast"] {
    --sky-top: #97a4ae;
    --sky-mid: #b3bbbf;
    --sky-bot: #d4c8b4;
    --sun-opacity: 0.25;
  }
  .hero[data-weather="rain"] {
    --sky-top: #6f7c8a;
    --sky-mid: #8c95a0;
    --sky-bot: #aba99e;
    --rain-opacity: 0.22;
    --sun-opacity: 0;
  }
  .hero[data-weather="snow"] {
    --sky-top: #c5d3df;
    --sky-mid: #dde2e6;
    --sky-bot: #e7e4d8;
    --sun-opacity: 0.3;
  }
  .hero[data-weather="storm"] {
    --sky-top: #3a4252;
    --sky-mid: #5a5e68;
    --sky-bot: #767168;
    --rain-opacity: 0.28;
    --sun-opacity: 0;
  }
  .hero[data-weather="night"] {
    --sky-top: #0e1924;
    --sky-mid: #16293a;
    --sky-bot: #1d2c38;
    --sun-opacity: 0;
  }

  /* Temperature shift (subtle warmth at horizon) */
  .hero[data-warmth="warm"][data-weather="clear"] { --sky-bot: #f0bf80; }
  .hero[data-warmth="warm"][data-weather="partly-cloudy"] { --sky-bot: #efc995; }
  .hero[data-warmth="cool"][data-weather="clear"] { --sky-bot: #d6dbd8; }
  .hero[data-warmth="cool"][data-weather="partly-cloudy"] { --sky-bot: #dadcd0; }

  /* Cloud density (parent group opacity multiplier) */
  .hero[data-cloud-density="low"] .cloud-layer { opacity: 0.55; }
  .hero[data-cloud-density="high"] .cloud-layer { opacity: 1.15; }

  /* Wind speed */
  .hero[data-wind-speed="slow"] { --cloud-speed-mult: 1.4; }
  .hero[data-wind-speed="fast"] { --cloud-speed-mult: 0.55; }

  /* Rain pattern overlay */
  .rain-layer {
    opacity: var(--rain-opacity, 0);
    transition: opacity 0.6s ease;
  }

  .sky {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .sky-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cloud-layer {
    transform-origin: center;
    will-change: transform;
    transition: opacity 0.6s ease;
  }

  .cloud-layer-slow {
    animation: drift-slow calc(70s * var(--cloud-speed-mult)) linear infinite alternate;
  }
  .cloud-layer-medium {
    animation: drift-medium calc(44s * var(--cloud-speed-mult)) linear infinite alternate;
  }
  .cloud-layer-fast {
    animation: drift-fast calc(28s * var(--cloud-speed-mult)) linear infinite alternate;
  }

  @keyframes drift-slow {
    from { transform: translateX(-14%); }
    to   { transform: translateX(14%); }
  }
  @keyframes drift-medium {
    from { transform: translateX(-22%); }
    to   { transform: translateX(22%); }
  }
  @keyframes drift-fast {
    from { transform: translateX(-32%); }
    to   { transform: translateX(32%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .cloud-layer { animation: none; }
  }

  /* Live weather readout, shown once the API responds. No panel; text sits
     directly on the sky with a soft halo for legibility. */
  .weather-readout {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding: 0.7rem 1rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-dim);
    text-shadow:
      0 1px 1px rgba(255, 255, 255, 0.45),
      0 0 6px rgba(255, 255, 255, 0.2);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.45s ease, transform 0.45s ease, color 0.4s ease;
    pointer-events: none;
  }

  .hero.weather-live .weather-readout {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .wr-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--teal);
    box-shadow:
      0 0 10px rgba(15, 118, 110, 0.55),
      0 0 2px rgba(255, 255, 255, 0.4);
    animation: wr-pulse 2s ease-in-out infinite;
  }

  @keyframes wr-pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.85); }
    50%      { opacity: 1;   transform: scale(1.18); }
  }

  .wr-label,
  .wr-loc {
    color: var(--teal-deep);
    font-weight: 600;
  }

  .wr-sep {
    color: var(--ink-faint);
    opacity: 0.6;
  }

  .wr-segment {
    color: var(--ink-dim);
  }

  .wr-link {
    color: var(--teal-deep);
    text-decoration: none;
    border-bottom: 1px dotted var(--teal);
    padding-bottom: 1px;
  }

  .wr-link:hover {
    color: var(--teal);
    border-bottom-color: var(--teal);
  }

  /* Dark sky states: invert text contrast and drop the white halo */
  .hero[data-weather="night"] .weather-readout,
  .hero[data-weather="storm"] .weather-readout,
  .hero[data-weather="rain"] .weather-readout {
    color: #ece8de;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.45),
      0 0 6px rgba(0, 0, 0, 0.25);
  }

  .hero[data-weather="night"] .wr-segment,
  .hero[data-weather="storm"] .wr-segment,
  .hero[data-weather="rain"] .wr-segment {
    color: #ece8de;
  }

  .hero[data-weather="night"] .wr-label,
  .hero[data-weather="night"] .wr-loc,
  .hero[data-weather="storm"] .wr-label,
  .hero[data-weather="storm"] .wr-loc,
  .hero[data-weather="rain"] .wr-label,
  .hero[data-weather="rain"] .wr-loc,
  .hero[data-weather="night"] .wr-link,
  .hero[data-weather="storm"] .wr-link,
  .hero[data-weather="rain"] .wr-link {
    color: #7fd3c4;
  }

  .hero[data-weather="night"] .wr-link,
  .hero[data-weather="storm"] .wr-link,
  .hero[data-weather="rain"] .wr-link {
    border-bottom-color: rgba(127, 211, 196, 0.55);
  }

  .hero[data-weather="night"] .wr-sep,
  .hero[data-weather="storm"] .wr-sep,
  .hero[data-weather="rain"] .wr-sep {
    color: rgba(236, 232, 222, 0.5);
  }

  @media (max-width: 720px) {
    .weather-readout {
      font-size: 0.66rem;
      gap: 0.4rem;
      padding: 0.55rem 0.6rem 0.7rem;
    }
    .wr-rh, .wr-sep-rh, .wr-time, .wr-sep-time {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wr-dot { animation: none; opacity: 0.85; }
    .weather-readout { transition: opacity 0.3s ease; transform: none; }
  }

  /* When night sky, lift hero text for contrast */
  .hero[data-weather="night"] .hero-name,
  .hero[data-weather="storm"] .hero-name { color: #f3efe9; }
  .hero[data-weather="night"] .hero-affiliation,
  .hero[data-weather="storm"] .hero-affiliation { color: #9bd0c8; }
  .hero[data-weather="night"] .hero-tag,
  .hero[data-weather="storm"] .hero-tag { color: #d6d1c4; }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 1.5rem;
    max-width: 920px;
    margin: 0 auto;
    text-align: left;
  }

  .hero-name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink);
    margin-bottom: 0.85rem;
  }

  .hero-affiliation {
    font-family: var(--font-mono);
    font-size: clamp(0.85rem, 1.4vw, 1rem);
    color: var(--teal-deep);
    margin-bottom: 0.85rem;
    letter-spacing: 0.01em;
  }

  .hero-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    color: var(--ink-dim);
    max-width: 42ch;
    line-height: 1.45;
  }

  /* ── About ────────────────────────────────────────── */

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    align-items: start;
  }

  @media (min-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr 200px;
      gap: 2.5rem;
    }
  }

  .about-photo {
