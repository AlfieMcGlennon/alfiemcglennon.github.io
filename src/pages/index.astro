        </a>
        <a href="https://www.linkedin.com/in/alfiemcglennon" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="mailto:alfie.mcglennon@outlook.com" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg>
        </a>
        <a href="/cv/" aria-label="CV">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </a>
      </div>
    </div>
  </div>
</Base>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 3.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(43, 124, 212, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(56, 189, 248, 0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(124, 58, 237, 0.03) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 600px;
  }

  .hero-greeting {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
    font-family: var(--font-mono);
  }

  .hero-name {
    font-size: clamp(3.5rem, 10vw, 6rem);
    font-weight: 800;
    line-height: 1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
  }

  .hero-tagline {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .hero-sub {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }

  .hero-links a {
    color: var(--text-muted);
    transition: color 0.25s ease, transform 0.25s ease;
    display: flex;
    align-items: center;
  }

  .hero-links a:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }

  .hero-links svg {
    width: 24px;
    height: 24px;
  }

  @media (max-width: 480px) {
    .hero-greeting { font-size: 0.9rem; }
    .hero-tagline { font-size: 1rem; }
    .hero-sub { font-size: 0.85rem; }
  }
</style>
